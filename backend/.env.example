# ── MongoDB ──
MONGO_URI=mongodb://localhost:27017/sansyar

# ── JWT ──
JWT_SECRET=یه_کلید_طولانی_و_تصادفی
JWT_EXPIRES_IN=7d

# ── Server ──
PORT=5000
NODE_ENV=development

# ── آدرس‌ها ──
# آدرس خود بک‌اند (زرین‌پال callback را به این آدرس می‌فرستد)
BASE_URL=http://localhost:5000
# آدرس فرانت‌اند (ریدایرکت نهایی بعد از پرداخت)
FRONTEND_URL=http://localhost:5000

# ── ایمیل (Resend) ──
RESEND_API_KEY=
RESEND_FROM=سانس‌چی <onboarding@resend.dev>

# ════════════════════════════════════════
# ── درگاه پرداخت زرین‌پال ──
# ════════════════════════════════════════
# مرچنت کد ۳۶ کاراکتری که از پنل زرین‌پال می‌گیری
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# برای تست = true (درگاه sandbox)؛ در production = false
ZARINPAL_SANDBOX=true
# واحد مبلغ ارسالی به درگاه: rial یا toman
# (قیمت‌های سایت تومان است؛ زرین‌پال v4 معمولاً ریال می‌خواهد → rial)
ZARINPAL_CURRENCY=rial
